# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for local dev. Get from Supabase Dashboard → Settings → API.
# Staging:    https://yqzycwuyhvzkbofwkazr.supabase.co  (dev.breaktapes.com)
# Production: https://kmdpufauamadwavqsinj.supabase.co  (app.breaktapes.com)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=   # "Anon public" key — safe to use in client-side code

# ── Environment flag ──────────────────────────────────────────────────────────
# Set to 'true' on dev.breaktapes.com (unlocks Pro features for beta testers)
VITE_IS_STAGING=false

# ── Wearable OAuth client IDs (optional for local dev) ───────────────────────
# Only needed if testing WHOOP/Garmin OAuth flows locally.
# WHOOP: developer-dashboard.whoop.com
# Garmin: developer.garmin.com (requires approval)
VITE_WHOOP_CLIENT_ID=
VITE_GARMIN_CLIENT_ID=

# ── Strava OAuth (optional for local dev) ────────────────────────────────────
# Only needed if testing Strava activity sync locally.
VITE_STRAVA_CLIENT_ID=
