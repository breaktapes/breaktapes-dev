{
  "name": "breaktapes",
  "version": "0.6.5.0",
  "private": true,
  "description": "BREAKTAPES React + Vite migration",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:react": "vitest run --project=react",
    "test:legacy": "vitest run --project=legacy",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost:3000"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "./tests/jest.setup.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "collectCoverageFrom": [],
    "verbose": true
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@deck.gl/core": "^9.3.0",
    "@deck.gl/layers": "^9.3.0",
    "@deck.gl/react": "^9.3.0",
    "@imgly/background-removal": "^1.7.0",
    "@supabase/supabase-js": "^2.103.2",
    "@tanstack/react-query": "^5.99.0",
    "framer-motion": "^12.38.0",
    "maplibre-gl": "^5.23.0",
    "onnxruntime-web": "1.21.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-map-gl": "^8.1.1",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  }
}
